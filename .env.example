# Copy this file to `.env` and fill in real values. Do not commit `.env`.

# ---- Database (Neon or other Postgres) ---------------------------------------
# Use the DIRECT (unpooled) endpoint for Alembic. Strip ?sslmode=require — SSL
# is passed via connect_args in src/database.py.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME

# ---- App ---------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Auth --------------------------------------------------------------------
# 32-byte URL-safe secret. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Cookie behavior. Keep secure=true in production (HTTPS); set false for local http.
REFRESH_COOKIE_SECURE=true

# ---- Google OAuth ------------------------------------------------------------
# Leave blank to disable /google/* routes (they return 503).
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Where the React frontend's OAuth-callback page lives.
FRONTEND_OAUTH_CALLBACK_URI=http://localhost:3000/auth/callback
